# Get a free API key at https://api.data.gov/signup/
VITE_COLLEGE_SCORECARD_API_KEY=your_api_key_here

# Anthropic API key for the AI chatbot — get one at https://console.anthropic.com/
# This goes in Vercel's environment variables (NOT prefixed with VITE_ — it stays server-side)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Formspree form ID for the feedback form — get one free at https://formspree.io/
# Sign up → New Form → copy the ID from the endpoint URL (e.g. "xabcdefg" from formspree.io/f/xabcdefg)
VITE_FORMSPREE_ID=your_formspree_form_id
